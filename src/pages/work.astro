---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const translations = {
    subtitle: { en: 'My Journey', es: 'Mi Trayectoria' },
    title: { en: 'Work Experience', es: 'Experiencia Laboral' },
    description: { en: 'A timeline of my professional journey and achievements in AI, Solutions Engineering, and Operations.', es: 'Una línea de tiempo de mi trayectoria profesional y logros en IA, ingeniería de soluciones y operaciones.' }
};

const workExperience = [
    {
        year: '2023 - Present',
        yearES: '2023 - Actualidad',
        title: 'Chief Technology Officer',
        titleES: 'Director de Tecnología (CTO)',
        company: "Liink'd",
        description: 'Designed an edge-first AI agent runtime utilizing Cloudflare Workers, LangChain, and Model Context Protocol (MCP). Engineered highly scalable infrastructure capable of deploying thousands of isolated, concurrently active AI agents equipped with persistent storage and vector memory. Built robust OpenAI-compatible developer APIs, enabling the seamless integration of internal agents with external applications. Developed dynamic automation systems to manage complex agent orchestration, tool integration, and efficient workflow execution. Authored comprehensive tutorials, demos, and technical documentation to accelerate developer onboarding for AI workflows.',
        descriptionES: 'Diseñé un entorno de ejecución de agentes de IA orientado al borde (edge-first) utilizando Cloudflare Workers, LangChain y Model Context Protocol (MCP). Diseñé infraestructura altamente escalable capaz de desplegar miles de agentes de IA aislados y activos simultáneamente, equipados con almacenamiento persistente y memoria vectorial. Construí robustas APIs compatibles con OpenAI para desarrolladores, permitiendo la integración fluida de agentes internos con aplicaciones externas. Desarrollé sistemas de automatización dinámica para gestionar la orquestación compleja de agentes, integración de herramientas y ejecución eficiente de flujos de trabajo. Autoricé tutoriales completos, demostraciones y documentación técnica para acelerar la incorporación de desarrolladores en flujos de trabajo de IA.'
    },
    {
        year: '2019 - 2023',
        yearES: '2019 - 2023',
        title: 'Customer Success Manager & Project Lead',
        titleES: 'Gerente de Éxito del Cliente y Líder de Proyecto',
        company: 'Benzinga Pro',
        description: 'Led high-impact churn reduction and plan upgrade initiatives, successfully achieving a 20% reduction in churn in 2022 and driving substantial user base growth. Designed and implemented custom support infrastructure utilizing Jira, Atlassian, Intercom APIs, and webhooks to significantly improve user-developer communication and issue resolution efficiency. Acted as the primary technical communication bridge between enterprise customers and engineering teams to facilitate effective issue diagnosis and platform improvement. Synthesized user community feedback into actionable technical requirements, directly contributing to developer tooling enhancements. Co-hosted corporate YouTube shows and weekly live X (Twitter) roundtables, growing the audience by 25,000 followers and establishing new revenue streams.',
        descriptionES: 'Lideré iniciativas de alto impacto para la reducción de la pérdida de clientes (churn) y actualizaciones de planes, logrando con éxito una reducción del 20% en el churn en 2022 e impulsando un crecimiento sustancial de la base de usuarios. Diseñé e implementé infraestructura de soporte personalizada utilizando APIs de Jira, Atlassian e Intercom y webhooks para mejorar significativamente la comunicación usuario-desarrollador y la eficiencia en la resolución de problemas. Actué como el puente técnico de comunicación principal entre los clientes empresariales y los equipos de ingeniería para facilitar el diagnóstico efectivo de problemas y la mejora de la plataforma. Sinteticé la retroalimentación de la comunidad de usuarios en requisitos técnicos accionables, contribuyendo directamente a las mejoras de las herramientas de desarrollo. Co-presenté programas corporativos de YouTube y mesas redondas en vivo semanales en X (Twitter), aumentando la audiencia en 25,000 seguidores y estableciendo nuevas fuentes de ingresos.'
    },
    {
        year: '2017 - 2019',
        yearES: '2017 - 2019',
        title: 'CSM, Project Manager & Software Developer',
        titleES: 'Gerente de Éxito, Director de Proyectos y Desarrollador de Software',
        company: 'Storetasker (prev. Ask Lorem)',
        description: 'Managed end-to-end client relationships on the leading Shopify freelance marketplace, expertly matching clients with best-fit developers for e-commerce projects. Built and deployed internal software applications used by over 20 accounts to streamline paperwork, forms, and team communication workflows. Directed project scoping, quoting, onboarding, and customer support resolution as the primary technical point of contact. Ensured successful project outcomes by equipping clients and expert freelancers with all necessary tools and architectural context.',
        descriptionES: 'Gestioné las relaciones con los clientes de extremo a extremo en el mercado de freelancers líder de Shopify, emparejando de manera experta a los clientes con los desarrolladores más adecuados para proyectos de comercio electrónico. Creé y desplegué aplicaciones de software internas utilizadas por más de 20 cuentas para agilizar el flujo de trabajo de papeleo, formularios y comunicación de equipos. Dirigí el alcance de proyectos, cotizaciones, incorporación y resolución de soporte al cliente como el punto de contacto técnico principal. Aseguré resultados exitosos del proyecto equipando a los clientes y freelancers expertos con todas las herramientas necesarias y contexto arquitectónico.'
    }
];
---

<Layout title={`Work | Brian Moir`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] pt-24 sm:pt-32 md:pt-48 pb-16 sm:pb-24 fade-in px-2 sm:px-0">
			<div class="max-w-2xl mb-12 sm:mb-16">
				<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-3 sm:mb-4 tracking-wider uppercase" data-en={translations.subtitle.en} data-es={translations.subtitle.es}>{translations.subtitle.en}</p>
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white" data-en={translations.title.en} data-es={translations.title.es}>
					{translations.title.en}
				</h1>
				<p class="mt-3 sm:mt-4 text-sm sm:text-lg text-gray-600 dark:text-gray-400" data-en={translations.description.en} data-es={translations.description.es}>
					{translations.description.en}
				</p>
			</div>

			<div class="space-y-8 sm:space-y-12 parallax-section">
				{
					workExperience.map((work) => (
						<div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-700 bg-transparent group cursor-pointer hover:scale-[1.02] transition-all duration-300">
							<div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-400 dark:bg-gray-500 group-hover:scale-125 group-hover:bg-primary transition-transform"></div>
							<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2 gap-2 sm:gap-0">
								<h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white" data-en={work.title} data-es={work.titleES}>{work.title}</h3>
								<span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 font-medium" data-en={work.year} data-es={work.yearES}>{work.year}</span>
							</div>
							<p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 font-semibold mb-2 sm:mb-3">{work.company}</p>
							<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 leading-relaxed" data-en={work.description} data-es={work.descriptionES}>{work.description}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.fade-in').forEach(el => {
				observer.observe(el);
			});

			window.addEventListener('scroll', () => {
				const scrolled = window.pageYOffset;
				document.querySelectorAll('.parallax-section').forEach(section => {
					const speed = 0.05;
					(section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
				});
			});
		});
	</script>
</Layout>
